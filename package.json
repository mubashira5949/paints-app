{
	"name": "@mubashira5949/paints-app",
	"description": "Reclaim Protocol Builder Monorepo",
	"version": "0.0.0",
	"workspaces": [
		"packages/backend",
		"packages/frontend"
	],
	"type": "module",
	"repository": {
		"url": "https://github.com/mubashira5949/paints-app",
		"type": "git"
	},
	"scripts": {
		"lint": "eslint --ext .js,.ts,.jsx,.tsx",
		"lint:fix": "npm run lint -- --fix",
		"test": "node --test packages/*/tests/*.test.ts --test-timeout=30000 --concurrency",
		"build": "npm run build --workspaces --if-present",
		"dev": "node --env-file=.development.env packages/app/scripts/dev.ts",
		"pgtyped:typegen": "sh scripts/pgtyped.sh"
	},
	"devDependencies": {
		"@adiwajshing/eslint-config": "github:adiwajshing/eslint-config",
		"@electric-sql/pglite": "^0.4.0",
		"@eslint/css": "^1.1.0",
		"@kristiandupont/recase": "^1.4.1",
		"@pgtyped/cli": "^2.4.3",
		"@types/node": "^24.0.0",
		"eslint": "^9.0.0",
		"kanel": "^3.16.0",
		"kanel-kysely": "^0.8.0",
		"openapi-typescript": "^7.13.0",
		"typescript": "^5.9.0"
	}
}