# Environment variables for the REMOTE DEV deployment (`make dev-deploy`).
# Loaded by docker compose --env-file for variable interpolation in
# docker-compose.yml. The vars listed under `environment:` for each service
# are passed into the containers; nginx uses DOMAIN_FRONTEND / DOMAIN_BACKEND
# to render its template at startup.

NODE_ENV=development

# Domains served by the dev nginx
DOMAIN_FRONTEND=app-dev.beautyflexinks.com
DOMAIN_BACKEND=service-dev.beautyflexinks.com

# Let's Encrypt notifications
LETSENCRYPT_EMAIL="smushaheed@gmail.com"

# Database configuration (dev RDS)
# Remember to encode the password if it contains special characters
DATABASE_URL="postgres://postgres:squid3344@beautyflexinks-db.cxey80y0wkwn.ap-south-1.rds.amazonaws.com:5432/beautyflexinks_db"
DB_SSL_ROOT_CERT="global-bundle.pem"

# JWT Token ECDSA Keys (Base64)
ES_PRIVATE_KEY=""
ES_PUBLIC_KEY="LS0tLS1CRUdJTiBQVUJMSUMgS0VZLS0tLS0KTUZrd0V3WUhLb1pJemowQ0FRWUlLb1pJemowREFRY0RRZ0FFSEVvZHlKeFZiSmVBdi9BNFNHWkJnQzlDVE1zeApNZ3YwbFp0RUk1M0pScVN0eXE1emNnSUNJMDlpUG5OMFhXT2ZyY2dERWE0RXZqNXpUTkxRbnYwbG9BPT0KLS0tLS1FTkQgUFVCTElDIEtFWS0tLS0tCg=="

