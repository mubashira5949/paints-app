# Environment variables for LOCAL development (npm run dev)
# Loaded by packages/backend/package.json's dev script via dotenv-cli.
# The local docker-compose at deploy/local/docker-compose.yaml exposes postgres
# on localhost:5432 with trust auth, so no password is needed.

NODE_ENV=development

# Local postgres (started by `npm run dev:db`)
DATABASE_URL="postgres://postgres:@localhost:5432/postgres"

# No SSL cert required when talking to the local postgres container
DB_SSL_ROOT_CERT=

# JWT Token ECDSA Keys (Base64) - shared dev keys, fine for local development
ES_PRIVATE_KEY=""
ES_PUBLIC_KEY="LS0tLS1CRUdJTiBQVUJMSUMgS0VZLS0tLS0KTUZrd0V3WUhLb1pJemowQ0FRWUlLb1pJemowREFRY0RRZ0FFSEVvZHlKeFZiSmVBdi9BNFNHWkJnQzlDVE1zeApNZ3YwbFp0RUk1M0pScVN0eXE1emNnSUNJMDlpUG5OMFhXT2ZyY2dERWE0RXZqNXpUTkxRbnYwbG9BPT0KLS0tLS1FTkQgUFVCTElDIEtFWS0tLS0tCg=="

ADMIN_PASSWORD=admin_password

# Vite dev server defaults to localhost:3000 when this is unset; left empty.
VITE_API_URL=
